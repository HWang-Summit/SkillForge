# SkillForge private environment template for all local skills.
# Copy this file to $HOME/.skillforge/env and fill local secrets there.
# Do not commit real API tokens or credentials.
# Add new skill variables here as needed, for example:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# MinerU precision API token. Leave empty to use free agent mode.
MINERU_API_TOKEN=

# Optional: force the Python executable used by mineru-pdf-parse.
# Example: MINERU_PYTHON=$HOME/miniconda3/bin/python
MINERU_PYTHON=

# Optional: conda env used when MINERU_PYTHON is not set.
MINERU_CONDA_ENV=base

# Zotero Web API key. Leave empty unless using zotero-cloud-library.
ZOTERO_API_KEY=

# Optional: force the Python executable used by zotero-cloud-library.
# Example: ZOTERO_PYTHON=$HOME/miniconda3/bin/python
ZOTERO_PYTHON=
